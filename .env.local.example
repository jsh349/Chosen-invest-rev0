# ── Scope key ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_*  Intentionally embedded in the browser bundle by Next.js.
#                Safe to expose only when the service enforces access control
#                at the API level (e.g. Supabase RLS, OAuth redirect checks).
# All others     Server-only. Never prefix with NEXT_PUBLIC_.
#                Never log, store in client state, or return in API responses.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix is intentional — URL and anon key are designed to be public.
# The anon key only grants permissions defined by Row Level Security (RLS) policies.
# User data safety depends on RLS being correctly enabled on every Supabase table.
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS entirely — keep it secret, server-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI providers (server-only) ────────────────────────────────────────────────
# Never prefix with NEXT_PUBLIC_ — these keys must never reach the browser bundle.
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Market data (server-only) ─────────────────────────────────────────────────
# Must NOT use NEXT_PUBLIC_ prefix — server-only secret, must never reach the browser bundle.
FINNHUB_API_KEY=your-finnhub-api-key

# ── Auth.js v5 (server-only) ──────────────────────────────────────────────────
# AUTH_SECRET     Signs and verifies session tokens. Critical — never expose.
#                 Generate with: openssl rand -base64 32
# AUTH_GOOGLE_SECRET  OAuth client secret. Server-only — never expose.
# AUTH_GOOGLE_ID      OAuth client ID. Server-only in this setup.
# AUTH_URL        Canonical base URL for auth callbacks (Auth.js v5 standard).
# NEXTAUTH_URL    Legacy alias for AUTH_URL kept for Auth.js v5 compatibility.
#                 Set to the same value as AUTH_URL.
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3001

# ── Turso / local SQLite (server-only) ────────────────────────────────────────
# TURSO_CONNECTION_URL  Use file:local.db for local dev; set to remote URL for prod.
# TURSO_AUTH_TOKEN      Leave empty for local file:// connections; required for remote.
TURSO_CONNECTION_URL=file:local.db
TURSO_AUTH_TOKEN=
